# --- npm security default (added 2026-06-09) ---
# Block automatic execution of dependency lifecycle scripts
# (preinstall / install / postinstall) during `npm install` / `npm ci`.
#
# WHY: defends against npm supply-chain worms (the "Miasma" / Red Hat /
# Shai-Hulud-class campaigns) whose payload runs from a dependency's
# install script and plants persistence in ~/.claude/settings.json
# (SessionStart hook) and .vscode/tasks.json (folderOpen task).
#
# This does NOT stop you installing or using packages. Pure-JS packages
# are unaffected. Only packages that compile native code or download a
# binary in a postinstall step need an extra step (see the workflow doc).
#
# Allow scripts for ONE intentional, trusted install:
#     npm install <pkg> --ignore-scripts=false
# Or compile a specific native package after a normal install:
#     npm rebuild <pkg> --ignore-scripts=false
#
# Full rationale + workflow (workspace root):
#     ../NPM-SECURITY-WORKFLOW.md   (C:\Users\sbirk\Documents\Code)
ignore-scripts=true
