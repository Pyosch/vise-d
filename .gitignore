# Python bytecode and compiled files
*.cpython
*.pyc
*.py[cod]
*$py.class
*.so
__pycache__/

# Project data and cache
data/*
cache/
mlruns/*
.dwd_cache/
.claude/

# Ship MaStR place-name lists for the online fallback (place names only, NOT plant data).
# These let the location dropdowns work without the multi-GB local open-mastr.db.
!data/mastr/
data/mastr/*
!data/mastr/*_locations.csv

# Streamlit secrets
.streamlit/secrets.toml

# Compressed and binary files
*.zip
*.json
*.log
*.db
*.sqlite
*.html

# Exception: ship the pre-rendered interactive map for the grid-expansion research page
!Analysis_expansion_costs/figures/interactive_expansion_map.json

# Virtual environments
venv/
ENV/
env/
.venv
vise/

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Testing
.pytest_cache/
.coverage
htmlcov/

# Build artifacts
build/
dist/
*.egg-info/

# Dashboard runtime data: static reference + (published) research results.
# Placed after the broad *.json/*.db ignores so the negations win.
!data/median_windpower_curve.csv
!data/figures/
data/figures/*
!data/figures/*.csv
!data/figures/trafo_loadings.json
!data/flexibility_profiles/
data/flexibility_profiles/*
!data/flexibility_profiles/flex_profiles_*.csv
